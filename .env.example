# Base de Datos MongoDB
# Obtener en: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/petcare?retryWrites=true&w=majority

# Configuración del Chatbot IA
# Proveedor de IA: 'groq' o 'huggingface'
AI_PROVIDER=groq

# API Key de Groq (Recomendado - Más rápido y gratuito)
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_aqui

# API Key de Hugging Face (Alternativa gratuita)
# Obtener en: https://huggingface.co/settings/tokens
HF_API_KEY=tu_api_key_aqui

# Nota: Si no configuras ninguna API key, el chatbot usará respuestas predefinidas
